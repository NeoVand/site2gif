{
  "manifest_version": 3,
  "name": "Talkover",
  "version": "1.0.0",
  "description": "Record your browser tab with webcam overlay — export as video or GIF. No account, no cloud.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "offscreen",
    "storage",
    "scripting"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Talkover — Record & Talk Over Your Tab",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-recording": {
      "suggested_key": {
        "default": "Alt+Shift+R",
        "mac": "Alt+Shift+R"
      },
      "description": "Start or stop recording"
    }
  }
}
